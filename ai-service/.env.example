# FastAPI settings
AI_SERVICE_PORT=8000

# Local PaddleOCR does not need an API key.
# Set to true after installing ai-service/requirements-ai.txt.
ENABLE_PADDLE_OCR=false
PADDLE_OCR_LANGUAGE=en

# Local LayoutLMv3 does not need an API key for public models.
# The default model downloads from Hugging Face when transformers/torch are installed.
ENABLE_LAYOUTLMV3=false
LAYOUTLMV3_MODEL=microsoft/layoutlmv3-base

# Optional only if you use private/gated Hugging Face models.
# Get token from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# Google Gemini API for AI summaries and assistant chat.
# Get key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Currency conversion used by the routing agent before comparing INR thresholds.
USD_TO_INR=83
EUR_TO_INR=90
GBP_TO_INR=105
